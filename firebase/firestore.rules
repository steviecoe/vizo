rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is a VG admin
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'vg_admin';
    }

    // Helper: check if user is impersonating a specific tenant
    function isImpersonating(tenantId) {
      return isAdmin()
        && request.auth.token.impersonating == true
        && request.auth.token.impersonatedTenantId == tenantId;
    }

    // Helper: check if user belongs to a tenant
    function isTenantMember(tenantId) {
      return request.auth != null && request.auth.token.tenantId == tenantId;
    }

    // Helper: check if user is tenant admin
    function isTenantAdmin(tenantId) {
      return request.auth != null
        && request.auth.token.tenantId == tenantId
        && request.auth.token.role == 'tenant_admin';
    }

    // Helper: user can access tenant data
    function canAccessTenant(tenantId) {
      return isAdmin() || isImpersonating(tenantId) || isTenantMember(tenantId);
    }

    // Platform config: readable by all authenticated, writable only via admin SDK
    match /platform/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // Admin users: only accessible via admin SDK
    match /admins/{uid} {
      allow read, write: if false; // Admin SDK only
    }

    // Audit log: only accessible via admin SDK
    match /auditLog/{entry} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // Tenant root documents
    match /tenants/{tenantId} {
      allow read: if canAccessTenant(tenantId);
      allow write: if false; // Admin SDK only (creation, updates)
    }

    // Tenant sub-collections
    match /tenants/{tenantId}/{subcollection}/{docId} {
      allow read: if canAccessTenant(tenantId);
      allow write: if false; // All writes go through Cloud Functions
    }

    // Catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
