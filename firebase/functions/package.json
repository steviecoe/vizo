{
  "name": "@vizo/functions",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:firebase-admin --external:firebase-functions --external:@google-cloud/secret-manager --external:@google-cloud/tasks --external:stripe --external:archiver --external:zod",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/tasks": "^5.5.0",
    "archiver": "^7.0.1",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vizo/shared": "workspace:*",
    "@types/archiver": "^6.0.3",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^3.0.7",
    "esbuild": "^0.27.4",
    "msw": "^2.7.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
